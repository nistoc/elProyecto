{
  "input_file": "transcript.md",
  "output_file": "transcript_fixed.md",
  
  "model": "gpt-4o-mini",
  "temperature": 0.2,
  "openai_api_key": "env:OPENAI_API_KEY",
  
  "batch_size": 10,
  "context_lines": 5,
  
  "save_intermediate": true,
  "intermediate_dir": "intermediate_fixes",
  
  "skip_if_exists": false,
  "verbose": true
}

