{
  "_comment": "Конфигурация для мультиязычного аудио (русский + испанский)",
  "_description": "Этот конфиг оптимизирован для аудио, где люди переключаются между русским и испанским языками",
  
  "file": "your_audio.m4a",
  "model": "gpt-4o-transcribe-diarize",
  
  "_language_help": "null = автоопределение (рекомендуется для мультиязычного), 'ru' = только русский, 'es' = только испанский",
  "language": null,
  
  "_prompt_help": "Примеры фраз на обоих языках + специфичные термины и имена. Макс ~200 слов.",
  "prompt": "Здравствуйте, как дела? Buenos días, ¿cómo estás? Хорошо, спасибо. Muy bien, gracias. Давайте поговорим. Vamos a hablar.",
  
  "temperature": 0.0,
  "openai_api_key": "env:OPENAI_API_KEY",
  "openai_base_url": null,
  "openai_organization": null,
  "response_format": "json",
  "timestamp_granularities": ["segment"],
  "openai_speaker_diarization": true,
  "md_output_path": "transcript.md",
  "raw_json_output_path": "openai_response.json",

  "pre_split": true,
  "chunk_overlap_sec": 2.0,
  "target_chunk_mb": 5,
  "chunking_strategy": "auto",
  "split_workdir": "chunks",
  "ffmpeg_path": "ffmpeg",
  "ffprobe_path": "ffprobe",
  "reencode_if_needed": true,
  "reencode_bitrate_kbps": 64,
  "concat_markdown": true,
  "chunk_naming": "{base}_part_%03d.m4a",
  "fallback_models": ["gpt-4o-mini-transcribe", "whisper-1"],

  "parallel_workers": 4,
  "save_per_chunk_json": true,
  "per_chunk_json_dir": "chunks_json",
  "cache_dir": "cache",
  
  "convert_to_wav": true,
  "wav_output_dir": "converted_wav",
  "save_intermediate_results": true,
  "intermediate_results_dir": "intermediate_results",

  "_diarization_help": "Включает определение спикеров через pyannote.audio",
  "use_diarization": true,
  "huggingface_token": "env:HUGGINGFACE_TOKEN",
  "diarization_model": "pyannote/speaker-diarization-3.1",
  "diarization_segments_dir": "diarization_segments",
  
  "_workspace_help": "Каждый файл обрабатывается в своей папке внутри workspace_root",
  "workspace_root": "processing_workspaces"
}

