# Copy this file to .env and fill in your values.
# The .env file is gitignored — your keys will not be committed.
#
# OpenAI API Key (required for refinement)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here
# Optional: for ASP.NET Core config (alternative to OPENAI_API_KEY)
# OpenAI__ApiKey=your-api-key-here
# OpenAI__BaseUrl=https://api.openai.com/
#
# Workspace root directory (required) — paths in requests are relative to this
WorkspaceRoot=path/to/your/workspace
