# Copy this file to .env and fill in your values.
# The .env file is gitignored — your keys will not be committed.
#
# OpenAI API Key (required for refinement)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here
# Optional: for ASP.NET Core config (alternative to OPENAI_API_KEY)
# OpenAI__ApiKey=your-api-key-here
# OpenAI__BaseUrl=https://api.openai.com/
#
# Workspace root (required): same tree as Agent04/Agent05 Jobs:WorkspacePath — prompts, job folders, refiner_threads
WorkspaceRoot=C:/path/to/agent-browser/runtime
# Optional host tuning (seconds, default 5)
# Agent06__ShutdownTimeoutSeconds=5
